# =============================================================
# Azure AI Search (Foundry IQ バックエンド)
# =============================================================
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<your-search-api-key>

# =============================================================
# Azure Blob Storage（インシデントデータ格納）
# =============================================================
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<storage>;EndpointSuffix=core.windows.net;AccountKey=<key>
BLOB_CONTAINER_NAME=incidents

# =============================================================
# Foundry IQ — Knowledge Base / Knowledge Source
# =============================================================
FOUNDRY_IQ_KNOWLEDGE_BASE_NAME=system-inquiry-kb
FOUNDRY_IQ_KNOWLEDGE_SOURCE_NAME=incidents-blob-ks

# =============================================================
# Azure AI Services (Embedding + Chat + Agent Service)
# AI Hub → AI Services 接続経由でモデルを利用
# =============================================================
AZURE_OPENAI_ENDPOINT=https://<your-ai-services>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-ai-services-api-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# =============================================================
# Foundry Agent Service — Project + Agent
# =============================================================
PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project>
PROJECT_CONNECTION_NAME=kb-mcp-connection
AGENT_NAME=system-inquiry-agent

# =============================================================
# GitHub (Function Tool が使用)
# =============================================================
GITHUB_TOKEN=<your-personal-access-token>
GITHUB_OWNER=<repository-owner>
GITHUB_REPO=<repository-name>
GITHUB_BRANCH=main
